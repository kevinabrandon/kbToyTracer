# Personal/machine-specific Claude instructions (CLAUDE.md itself is shared)
CLAUDE.local.md

# Build artifacts and render outputs
*.o
*.obj
# ... but Wavefront mesh models used by the golden tests are not object files
!tests/scenes/models/*.obj
*.exe
*.ppm
a.out
kbtoytracer
build/
__pycache__/
*.pyc

# Tooling and assets not needed to run the gallery (kept locally, not published
# here) -- except kbSPD, the revived SPD scene generators, which build and run
# anywhere (kbSPD/.gitignore keeps its binaries out)
tools/*
!tools/kbSPD/
assets/
legacy/

# Scratch scenes: experiment/one-off .sdf files not used by any gallery script (kept
# locally for now, not published).
scratch-scenes/

# Loose top-level renders (the committed showcase lives in gallery/)
/*.png
scenes/*.png

# Scenes: publish only the ones the gallery uses. The 229k-triangle teapot ships
# gzipped (scenes/teapot-bvh-hq.sdf.gz) and is decompressed on demand by
# gallery_lib.ensure_scene(); the raw .sdf stays out of the repo.
scenes/*
!scenes/scene1-reflection.sdf
!scenes/scene1-sphereonly.sdf
!scenes/scene2-matrix.sdf
!scenes/scene1-reflection-room.sdf
!scenes/scene2-matrix-room.sdf
!scenes/scene3-spherelight.sdf
!scenes/scene4-refraction.sdf
!scenes/scene5-checker-floor.sdf
!scenes/scene6-marble.sdf
!scenes/scene7-dof.sdf
!scenes/scene8-imports.sdf
!scenes/dof-dragon.sdf
!scenes/room-spheres.sdf
!scenes/room-ellipsoids-plain.sdf
!scenes/room-ellipsoids-reflect.sdf
!scenes/room-ellipsoids-refract-70.sdf
!scenes/spherelight.sdf
!scenes/blurry.sdf
!scenes/refract-focus.sdf
!scenes/teapot-bvh-hq.sdf.gz
!scenes/teapot-trio.sdf
!scenes/cornell-box.sdf
!scenes/dragon.sdf
!scenes/lucy.sdf
# Imported model library (see scenes/models/README.md for provenance)
!scenes/models
!scenes/models/**
.claude/
