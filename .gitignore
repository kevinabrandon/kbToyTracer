# Build artifacts and render outputs
*.o
*.obj
*.exe
*.ppm
a.out
kbtoytracer
build/
__pycache__/
*.pyc

# Tooling and assets not needed to run the gallery (kept locally, not published here)
tools/
assets/
legacy/

# Scratch scenes: experiment/one-off .sdf files not used by any gallery script (kept
# locally for now, not published).
scratch-scenes/

# Loose top-level renders (the committed showcase lives in gallery/)
/render-*.png
/wallpaper-*.png

# Scenes: publish only the ones the gallery uses. The 229k-triangle teapot ships
# gzipped (scenes/teapot-bvh-hq.sdf.gz) and is decompressed on demand by
# gallery_lib.ensure_scene(); the raw .sdf stays out of the repo.
scenes/*
!scenes/scene1-reflection.sdf
!scenes/scene1-sphereonly.sdf
!scenes/scene2-matrix.sdf
!scenes/room-spheres.sdf
!scenes/room-ellipsoids-plain.sdf
!scenes/room-ellipsoids-reflect.sdf
!scenes/room-ellipsoids-refract-70.sdf
!scenes/spherelight.sdf
!scenes/blurry.sdf
!scenes/refract-focus.sdf
!scenes/teapot-bvh-hq.sdf.gz
