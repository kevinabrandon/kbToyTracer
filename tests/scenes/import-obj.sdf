# obj-import regression scene: a quad-faced cube (no normals -> fan
# triangulation + flat shading) and an icosphere with vertex normals
# (-> kbSmoothTriangle Phong-interpolated shading), each instanced twice
# with different transforms and materials.  The non-uniform scale on the
# blue icosphere exercises the inverse-transpose normal transform on
# interpolated normals.

eye          (0.0, -8.0, 3.2)
lookat       (0.0, 0.0, 0.8)
up           (0.0, 0.0, 1.0)
vpdist       2.5

amblight     [0.2, 0.2, 0.2]
bgcolor      [0.15, 0.25, 0.35]

import models/cube.obj      as cube
import models/icosphere.obj as ball

begin BVH

    point        (-3.0, -6.0, 10.0)
    emission     [1, 1, 1]

    # the floor
    box          (-7, -4, -1) (7, 6, 0)
    diffuse      [0.7, 0.7, 0.6]
    specular     [0, 0, 0]
    reflectivity 0
    Phong_exp    0

    instance     cube
    rotate       (0, 0, 1) 30
    scale        0.8
    translate    (-3.2, 0.4, 0.8)
    diffuse      [0.9, 0.35, 0.2]
    specular     [1, 1, 1]
    Phong_exp    15

    instance     cube
    scale        (1.1, 1.1, 0.35)
    translate    (0, 1.2, 0.35)
    diffuse      [0.85, 0.75, 0.3]

    instance     ball
    translate    (-0.9, -1.4, 0.9)
    diffuse      [0.3, 0.8, 0.4]
    specular     [1, 1, 1]
    Phong_exp    25

    instance     ball
    scale        (1.6, 1.0, 1.0)
    translate    (2.9, 0.2, 1.0)
    diffuse      [0.25, 0.45, 0.9]
    specular     [1, 1, 1]
    Phong_exp    25
    reflectivity 0.25

end
